  },
  "dependencies": {
    "@noble/hashes": "^1.4.0",
    "occproof": "file:../../"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

{
  "name": "occ-paperclip",
  "version": "1.0.1",
  "description": "Paperclip with OCC MCP-per-agent support — orchestrate governed AI agent teams",
  "type": "module",
  "bin": {
    "occ-paperclip": "dist/index.js"
  },
  "keywords": [
    "paperclip",
    "occ",
    "ai",
    "agents",
    "orchestration",
    "mcp",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mikeargento/occ",
    "directory": "packages/paperclip/cli"
  },
  "homepage": "https://occ.wtf",
  "bugs": {
    "url": "https://github.com/mikeargento/occ/issues"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "node --input-type=module -e \"import esbuild from 'esbuild'; import config from './esbuild.config.mjs'; await esbuild.build(config);\" && chmod +x dist/index.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "@paperclipai/server": "2026.325.0",
    "commander": "^13.1.0",
    "dotenv": "^17.0.1",
    "drizzle-orm": "0.38.4",
    "embedded-postgres": "^18.1.0-beta.16",
    "picocolors": "^1.1.1",
    "postgres": "^3.4.5",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}

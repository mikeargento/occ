{
  "name": "occ-mcp-proxy",
  "version": "2.3.0",
  "description": "Policy enforcement for AI tool calls. Default-deny control for any MCP server.",
  "author": "Mike Argento",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "occ-mcp-proxy": "dist/index.js",
    "occ-agent": "dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "dashboard",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikeargento/occ.git",
    "directory": "packages/mcp-proxy"
  },
  "keywords": [
    "occ",
    "mcp",
    "proxy",
    "occ-agent",
    "policy",
    "enforcement",
    "agent"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@noble/hashes": "^1.4.0",
    "occ-agent": "^1.0.0",
    "occ-policy-sdk": "^1.0.0",
    "occ-stub": "^1.0.0",
    "occproof": "file:../.."
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

{
  "version": "occ/policy/1",
  "name": "Customer Service Agent",
  "description": "Policy for a customer service agent. Can read orders, check eligibility, issue refunds up to $50, and send emails. Cannot delete users or drop tables.",
  "createdAt": 1710432000000,
  "globalConstraints": {
    "maxSpendCents": 5000,
    "blockedTools": ["delete-user", "drop-table"],
    "rateLimit": {
      "maxCalls": 100,
      "windowMs": 3600000
    }
  },
  "skills": {
    "process-refund": {
      "name": "Process Refund",
      "tools": ["read-order", "check-eligibility", "issue-refund", "send-email"]
    },
    "customer-lookup": {
      "name": "Customer Lookup",
      "tools": ["search-db", "read-order"]
    }
  },
  "toolConstraints": {
    "issue-refund": {
      "maxSpendPerCallCents": 5000,
      "rateLimit": {
        "maxCalls": 10,
        "windowMs": 3600000
      }
    },
    "send-email": {
      "rateLimit": {
        "maxCalls": 20,
        "windowMs": 3600000
      }
    }
  }
}

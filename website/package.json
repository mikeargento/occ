    "@noble/hashes": "^1.8.0",
    "c2pa": "^0.30.17",
    "cbor-x": "^1.6.4",
    "fflate": "^0.8.2",
    "heic2any": "^0.0.4",
    "katex": "^0.16.38",
    "next": "16.1.6",
    "occproof": "^1.0.2",
    "qrcode.react": "^4.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "resend": "^6.10.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",

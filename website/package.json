  "scripts": {
    "copy-c2pa-assets": "mkdir -p public/c2pa && cp node_modules/c2pa/dist/assets/wasm/toolkit_bg.wasm public/c2pa/ && cp node_modules/c2pa/dist/c2pa.worker.min.js public/c2pa/",

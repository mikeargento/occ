{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "occ-docs",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "docs", "-l", "3000"],
      "port": 3000
    },
    {
      "name": "occ-website",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--port", "3001"],
      "port": 3001,
      "cwd": "website"
    },
    {
      "name": "occ-agent",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3002,
      "cwd": "packages/commandcentral"
    },
    {
      "name": "paperclip",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "src/index.ts"],
      "port": 3100,
      "cwd": "packages/paperclip/server",
      "env": {
        "OCC_MODE": "tee",
        "PAPERCLIP_MIGRATION_AUTO_APPLY": "true"
      }
    }
  ]
}
